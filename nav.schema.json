{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/grovetools/nav/internal/manager/tmux-config",
  "$defs": {
    "GroupRef": {
      "properties": {
        "prefix": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "persist": true,
        "sessions": {
          "additionalProperties": {
            "$ref": "#/$defs/TmuxSessionConfig"
          },
          "type": "object"
        },
        "active": {
          "type": "boolean"
        }
      },
      "type": "object",
      "required": [
        "prefix"
      ]
    },
    "TmuxSessionConfig": {
      "properties": {
        "path": {
          "type": "string"
        }
      },
      "type": "object",
      "required": [
        "path"
      ]
    }
  },
  "properties": {
    "prefix": {
      "type": "string",
      "description": "Prefix key for nav bindings. Options: '\u003cprefix\u003e' (default)",
      "x-layer": "global",
      "x-priority": "69"
    },
    "available_keys": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "description": "Keys available for tmux pane shortcuts",
      "x-important": true,
      "x-layer": "global",
      "x-priority": "70"
    },
    "show_child_processes": {
      "type": "boolean",
      "description": "Show child processes in pane list",
      "x-layer": "global",
      "x-priority": "71"
    },
    "groups": {
      "additionalProperties": {
        "$ref": "#/$defs/GroupRef"
      },
      "type": "object",
      "description": "Workspace groups for multiple key prefixes"
    },
    "confirm_key_updates": {
      "type": "boolean",
      "description": "Show confirmation prompts for bulk key update operations (L/U). Defaults to true.",
      "x-layer": "global",
      "x-priority": "72"
    }
  },
  "type": "object",
  "title": "Grove Nav Configuration",
  "description": "Schema for the 'nav' extension in grove.toml. For backwards compatibility, 'tmux' is also supported."
}